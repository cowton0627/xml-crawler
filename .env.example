# 複製這個檔案成 .env 後填入實際值。.env 不會進 git。
# RSSHub 完整環境變數清單: https://docs.rsshub.app/deploy/config

# --- 基本 (通常不用改) ---
NODE_ENV=production
CACHE_TYPE=redis
REDIS_URL=redis://redis:6379/

# --- Instagram ---
# IG 有兩條 RSSHub 路由,吃的變數不同 (經實測 v24.15.0 確認):
#   /instagram/user/:username   = private-api,只吃 IG_USERNAME/IG_PASSWORD,不支援 2FA
#   /instagram/2/user/:username = web-api,吃 IG_COOKIE (建議用這條,見 config.yaml)
# 注意: 連「公開帳號」都需要登入態,匿名請求會被 IG 回 429 Too Many Requests。
# 不需要商業/creator 帳號,也不用官方 Graph API token,普通分身的 cookie 即可。
# 強烈建議用「分身帳號」(最好關掉 2FA),不要用本帳。
#
# IG_COOKIE 取得方式: 用分身登入 IG → DevTools → Application → Cookies →
#                     複製整個 cookie 字串 (sessionid=...; csrftoken=...; ds_user_id=... 等)
IG_COOKIE=
# private-api 路由才會用到下面兩個 (一般用 IG_COOKIE 即可,不必填):
# IG_USERNAME=
# IG_PASSWORD=
# 選填: 若被 IG 風控可掛 proxy, 例: IG_PROXY=socks://127.0.0.1:1080
# IG_PROXY=

# --- Threads ---
# Threads 與 IG 共用帳號生態,通常重用 IG 分身
THREADS_USERNAME=
THREADS_PASSWORD=

# --- Facebook ---
# 只能抓 Public Page。需要 token (Graph API) 或 cookie
FB_COOKIE=

# --- YouTube ---
# 用官方 RSS 就好,通常不需要 API key
# 若要用 Data API v3 提升穩定度再填:
# YOUTUBE_KEY=
