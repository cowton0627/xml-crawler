# 複製這個檔案成 .env 後填入實際值。.env 不會進 git。
# RSSHub 完整環境變數清單: https://docs.rsshub.app/deploy/config

# --- 基本 (通常不用改) ---
NODE_ENV=production
CACHE_TYPE=redis
REDIS_URL=redis://redis:6379/

# --- Instagram ---
# RSSHub 路由 /instagram/user/:username 需要登入態
# 強烈建議用「分身帳號」,不要用本帳
# 取得方式: 瀏覽器登入 IG → DevTools → Application → Cookies → 複製整個 cookie 字串
IG_USERNAME=
IG_PASSWORD=
# 或用 cookie (較不易觸發 2FA):
# IG_COOKIE=

# --- Threads ---
# Threads 與 IG 共用帳號生態,通常重用 IG 分身
THREADS_USERNAME=
THREADS_PASSWORD=

# --- Facebook ---
# 只能抓 Public Page。需要 token (Graph API) 或 cookie
FB_COOKIE=

# --- YouTube ---
# 用官方 RSS 就好,通常不需要 API key
# 若要用 Data API v3 提升穩定度再填:
# YOUTUBE_KEY=
